# Server
NODE_ENV=development
PORT=3000
DATABASE_URL=
# Generate both with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
SERA_CONFIG_ENCRYPTION_KEY=

# Optional override. Defaults to http://localhost:3000 in development and https://pay.sera.cx in production.
PAYMENT_BASE_URL=

SERA_API_BASE_URL=https://api.sera.cx/api/v1
SERA_API_TESTNET_BASE_URL=https://api.testnet.sera.cx/api/v1
SERA_API_KEY=
SERA_WEBHOOK_SECRET=
GOLDSKY_GRAPHQL_URL=

# Sera MCP Configuration for Multi-Currency Support
SERA_NETWORK=mainnet
POLICY_PRESET=standard

# Set to true for demo mode when Sera API is unavailable
SERA_MOCK_MODE=false

VITE_PRIVY_APP_ID=
VITE_PRIVY_CLIENT_ID=
# Leave false for localhost unless your Privy client ID is allowed for local origins.
VITE_PRIVY_USE_CLIENT_ID_IN_DEV=false
PRIVY_SECRET=
PRIVY_JWKS=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://sera.cx,https://www.sera.cx,https://app.sera.cx,https://dev.sera.cx,https://app.dev.sera.cx,https://testnet.sera.cx,https://app.testnet.sera.cx,https://pay.sera.cx,https://wallet.sera.cx

VITE_APP_BASE_URL=

# Optional Cloudflare R2 object storage for merchant logos and menu images.
# Use server-only names for secrets. Do not prefix R2 credentials with VITE_.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_API_TOKEN=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_PUBLIC_URL=
